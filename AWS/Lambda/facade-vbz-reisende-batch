import urllib.request
import boto3
from datetime import datetime

s3_client = boto3.client('s3')

def lambda_handler(event, context):
    BUCKET_NAME = "facade-project-academy-20251122-143025"
    BASE_URL = "https://data.stadt-zuerich.ch/dataset/vbz_fahrgastzahlen_ogd/download"

    print("Downloading REISENDE.csv...")

    with urllib.request.urlopen(f"{BASE_URL}/REISENDE.csv", timeout=120) as response:
        csv_data = response.read()

    print(f"✅ Downloaded. Uploading to S3...")

    s3_client.put_object(
        Bucket=BUCKET_NAME,
        Key="bronze/vbz/REISENDE_RAW.csv",
        Body=csv_data,
        ContentType='text/csv'
    )

    print(f"✅ Saved to S3: s3://{BUCKET_NAME}/bronze/vbz/REISENDE_RAW.csv")

    return {'statusCode': 200, 'message': 'Raw REISENDE.csv saved'}
