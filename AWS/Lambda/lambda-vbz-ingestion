  import json
  import urllib.request
  import boto3
  import csv
  from io import StringIO
  from datetime import datetime

  s3_client = boto3.client('s3')

  def lambda_handler(event, context):
      """
      Fetch VBZ tables with client-side filtering of REISENDE by day type

      Strategy:
      - Download small tables completely
      - Download REISENDE once, filter by Tagtyp (day type), save separate files
      """

      BUCKET_NAME = "facadebronzebucket"
      BASE_URL = "https://data.stadt-zuerich.ch/dataset/vbz_fahrgastzahlen_ogd/download"

      small_tables = {
          'HALTESTELLEN': f"{BASE_URL}/HALTESTELLEN.csv",
          'LINIE': f"{BASE_URL}/LINIE.csv",
          'TAGTYP': f"{BASE_URL}/TAGTYP.csv",
          'GEFAESSGROESSE': f"{BASE_URL}/GEFAESSGROESSE.csv"
      }

      year = event.get('year', 2025)
      timestamp = datetime.utcnow().isoformat()
      results = {}

      try:
          print(f"Starting VBZ data ingestion for {year}")

          # ========== SMALL TABLES ==========
          print("\n📥 Downloading small reference tables...")
          for table_name, url in small_tables.items():
              try:
                  print(f"   {table_name}...", end=' ')

                  with urllib.request.urlopen(url, timeout=60) as response:
                      csv_data = response.read().decode('utf-8')

                  csv_reader = csv.DictReader(StringIO(csv_data))
                  records = list(csv_reader)
                  record_count = len(records)

                  print(f"✅ {record_count} records")

                  # Save to S3
                  output_data = {
                      'fetch_timestamp': timestamp,
                      'year': year,
                      'table_name': table_name,
                      'record_count': record_count,
                      'data': records
                  }

                  s3_key = f"vbz/{year}/vbz_{table_name.lower()}.json"
                  s3_client.put_object(
                      Bucket=BUCKET_NAME,
                      Key=s3_key,
                      Body=json.dumps(output_data, indent=2, ensure_ascii=False),
                      ContentType='application/json'
                  )

                  results[table_name] = {
                      'status': 'success',
                      'records': record_count,
                      's3_location': f"s3://{BUCKET_NAME}/{s3_key}"
                  }

              except Exception as e:
                  print(f"❌ Error: {str(e)}")
                  results[table_name] = {'status': 'failed', 'error': str(e)}

          # ========== LARGE TABLE: REISENDE (filter by day type) ==========
          print("\n📥 Downloading REISENDE and filtering by day type...")
          try:
              reisende_url = f"{BASE_URL}/REISENDE.csv"
              print(f"   Downloading REISENDE.csv (this may take 2-3 minutes)...")

              with urllib.request.urlopen(reisende_url, timeout=300) as response:
                  csv_data = response.read().decode('utf-8')
                  print(f"   ✅ Download complete. Parsing and filtering...")

              csv_reader = csv.DictReader(StringIO(csv_data))

              # Group records by Tagtyp (day type)
              records_by_tagtyp = {}
              total_records = 0

              for row in csv_reader:
                  total_records += 1
                  tagtyp_id = row.get('Tagtyp_Id', 'unknown')

                  if tagtyp_id not in records_by_tagtyp:
                      records_by_tagtyp[tagtyp_id] = []
                  records_by_tagtyp[tagtyp_id].append(row)

                  # Progress indicator
                  if total_records % 100000 == 0:
                      print(f"   Processed {total_records} records...")

              print(f"   ✅ Total records: {total_records}")
              print(f"   Found {len(records_by_tagtyp)} day types: {list(records_by_tagtyp.keys())}")

              # Save each day type separately
              for tagtyp_id, records in records_by_tagtyp.items():
                  output_data = {
                      'fetch_timestamp': timestamp,
                      'year': year,
                      'table_name': 'REISENDE',
                      'tagtyp_id': tagtyp_id,
                      'record_count': len(records),
                      'data': records
                  }

                  s3_key = f"vbz/{year}/vbz_reisende_tagtyp_{tagtyp_id}.json"

                  s3_client.put_object(
                      Bucket=BUCKET_NAME,
                      Key=s3_key,
                      Body=json.dumps(output_data, indent=2, ensure_ascii=False),
                      ContentType='application/json'
                  )

                  print(f"   ✅ Tagtyp {tagtyp_id}: {len(records)} records → S3")

                  results[f'REISENDE_Tagtyp_{tagtyp_id}'] = {
                      'status': 'success',
                      'records': len(records),
                      's3_location': f"s3://{BUCKET_NAME}/{s3_key}"
                  }

              results['REISENDE_TOTAL'] = {
                  'status': 'success',
                  'total_records': total_records,
                  'day_types': len(records_by_tagtyp)
              }

          except Exception as e:
              print(f"   ❌ Error with REISENDE: {str(e)}")
              results['REISENDE'] = {'status': 'failed', 'error': str(e)}

          print(f"\n✅ VBZ data ingestion completed")

          return {
              'statusCode': 200,
              'body': json.dumps({
                  'message': 'VBZ data ingestion complete',
                  'year': year,
                  'results': results,
                  's3_base_location': f"s3://{BUCKET_NAME}/vbz/{year}/"
              }, ensure_ascii=False)
          }

      except Exception as e:
          print(f"❌ Fatal error: {str(e)}")
          import traceback
          traceback.print_exc()
          return {
              'statusCode': 500,
              'body': json.dumps({
                  'message': f'Error: {str(e)}',
                  'year': year
              }, ensure_ascii=False)
          }
